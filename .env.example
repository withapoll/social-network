# Скопируйте этот файл в .env и при необходимости поправьте значения.
# Параметры подключения к локальному PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=social_network
DB_USER=social
DB_PASSWORD=social
DB_PASSWORD_FILE=

# Хост и порт, на которых поднимается приложение.
APP_HOST=0.0.0.0
APP_PORT=8000
